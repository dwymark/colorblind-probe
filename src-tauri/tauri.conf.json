{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Colorblind Probe",
  "version": "0.1.0",
  "identifier": "com.dwymark.colorblind-probe",
  "build": {
    "frontendDist": "../frontend",
    "beforeBuildCommand": "mkdir -p ../frontend && cp ../index.html ../frontend/index.html",
    "beforeDevCommand": "mkdir -p ../frontend && cp ../index.html ../frontend/index.html"
  },
  "app": {
    "windows": [
      {
        "title": "Indicator Light Detector",
        "width": 800,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' mediastream:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
